{
  "name": "@spycore/cli",
  "version": "0.5.0",
  "description": "SpyCode — SpyCore's AI coding agent and CLI: chat, autonomous agent runs with approval gates and rewind, BYOK providers, skills, MCP client, and an ACP server for IDEs.",
  "license": "Apache-2.0",
  "author": {
    "name": "SpyCore AI, Inc.",
    "email": "support@spycore.ai",
    "url": "https://spycore.ai"
  },
  "homepage": "https://spycore.ai/spycode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SpyCoreAI/SpyCode.git"
  },
  "bugs": {
    "url": "https://spycore.ai/support"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "main": "./build/index.js",
  "bin": {
    "spycore": "bin/spycore.js"
  },
  "files": [
    "build",
    "bin",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE",
    "THIRD-PARTY-LICENSES",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "build:dev": "tsc",
    "dev": "tsup --watch",
    "test": "vitest run",
    "smoke:live": "tsup --config scripts/smoke-live/tsup.config.ts && node scripts/smoke-live/smoke-live.mjs",
    "lint": "tsc --noEmit",
    "gen:licenses": "node scripts/gen-third-party-licenses.mjs",
    "prepublishOnly": "pnpm lint && pnpm build && pnpm test"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^11.1.0",
    "conf": "^11.0.0",
    "diff": "^9.0.0",
    "eventsource-parser": "^3.0.6",
    "form-data": "^4.0.6",
    "globby": "^16.2.0",
    "ink": "^7.0.5",
    "marked": "^18.0.4",
    "mime-types": "^2.1.35",
    "ora": "^7.0.1",
    "react": "^19.2.6",
    "undici": "^6.27.0"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.15",
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^3.2.6"
  },
  "keywords": [
    "spycore",
    "spycode",
    "ai",
    "cli",
    "agent",
    "coding-agent",
    "llm",
    "chat",
    "mcp",
    "acp"
  ]
}
